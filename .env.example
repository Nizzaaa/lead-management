# Anthropic API-Key für die KI-Funktionen (Lead-Scoring, E-Mail-Entwürfe, Empfehlungen).
# Ohne diesen Key läuft die App vollständig, nur die KI-Buttons sind dann inaktiv.
ANTHROPIC_API_KEY=sk-ant-...
# Alternativ als Datei-/Docker-Secret bereitstellen (dann NICHT in der Env sichtbar):
# ANTHROPIC_API_KEY_FILE=/run/secrets/anthropic_api_key

# Passwort für die PostgreSQL-Datenbank (wird in docker-compose verwendet).
# PFLICHT: Die Compose-Stacks starten ohne ein gesetztes Passwort nicht mehr
# (kein unsicherer Standard mehr). Bitte ein sicheres, einzigartiges Passwort
# eintragen. Sonderzeichen sind erlaubt (die App nutzt PG*-Variablen, keine URL).
POSTGRES_PASSWORD=

# Optionaler Port der Web-App (Standard: 3000)
# PORT=3000

# Nur Entwicklung (docker-compose.dev.yml): Host-Port des DB-Viewers Adminer.
# Standard 8080, nur an 127.0.0.1 gebunden. Anpassen, falls 8080 belegt ist.
# ADMINER_PORT=8080

# --- Logging ---------------------------------------------------------------
# Log-Level: debug | info | warn | error (Standard: info)
# LOG_LEVEL=info
# Menschenlesbare Ausgabe statt JSON-Lines (für die lokale Entwicklung):
# LOG_PRETTY=1

# --- Einbettung in Nextcloud (iframe) --------------------------------------
# Erlaubt das Einbetten der App per iframe (Nextcloud-App "External Sites").
# Auf die Origin der Nextcloud-Instanz setzen, z. B.:
# FRAME_ANCESTORS=

# --- Cloudflare Access (JWT-Verifikation) ----------------------------------
# Wenn die App hinter Cloudflare Access läuft: beide Werte setzen, damit die App
# das signierte Token "Cf-Access-Jwt-Assertion" kryptografisch prüft, statt dem
# fälschbaren Klartext-Header zu vertrauen. Dann werden sensible API-Zugriffe
# ohne gültiges Token mit 403 abgelehnt. Leer = aus (lokal/intern).
#   CF_ACCESS_TEAM_DOMAIN: deine Team-Domain, z. B. team.cloudflareaccess.com
#   CF_ACCESS_AUD:         Application Audience (AUD) Tag der Access-Application
# CF_ACCESS_TEAM_DOMAIN=
# CF_ACCESS_AUD=

# --- Logout-Button ---------------------------------------------------------
# Abmelde-Ziel des vorgeschalteten Auth-Proxys (Logout-Button in der Topbar).
# Default passt zu Cloudflare Access. Für oauth2-proxy z. B.:
#   LOGOUT_URL=/oauth2/sign_out
# Leer setzen, um den Logout-Button auszublenden.
# LOGOUT_URL=/cdn-cgi/access/logout

# --- Kalender-Synchronisation (CalDAV, z. B. Nextcloud) --------------------
# Wiedervorlagen (nächster Schritt + Datum) werden zusätzlich als Termine in
# einen CalDAV-Kalender geschrieben. Einseitig (App → Kalender): Erledigen oder
# Entfernen der Wiedervorlage – und gewonnene/verlorene oder gelöschte Leads –
# löschen den Termin wieder. Aktiv nur, wenn URL + Benutzer + Passwort gesetzt
# sind; sonst läuft die App unverändert ohne Kalender. Anleitung:
# docs/nextcloud-caldav.md
#
# Kollektions-URL des Ziel-Kalenders (mit abschließendem „/“). In Nextcloud:
# Kalender → „…“ → Link/„CalDAV-Adresse kopieren“. Form:
#   https://cloud.example.de/remote.php/dav/calendars/<benutzer>/<kalender>/
# CALDAV_URL=
# CALDAV_USERNAME=
# Passwort – am besten ein Nextcloud-App-Passwort (Einstellungen → Sicherheit →
# „App-Passwort/Gerät erstellen“), nicht das Login-Passwort.
# CALDAV_PASSWORD=
# Alternativ als Datei-/Docker-Secret (dann NICHT in der Env sichtbar):
# CALDAV_PASSWORD_FILE=/run/secrets/caldav_password
#
# Optional: Uhrzeit "HH:MM" für den Termin. Leer = Ganztags-Termin (Standard).
# CALDAV_EVENT_TIME=09:00
# Optional: Termindauer in Minuten (nur bei gesetzter Uhrzeit; Standard 30).
# CALDAV_EVENT_DURATION_MIN=30
# Optional: Erinnerung X Minuten vor Beginn (VALARM). 0/leer = keine Erinnerung.
# CALDAV_REMINDER_MIN=0
#
# Öffentliche Basis-URL der App – für den Rücklink „Lead öffnen“ im Termin.
# Ohne Wert wird sie aus den Request-Headern abgeleitet (hinter einem Proxy
# am besten explizit setzen), z. B.:
# APP_BASE_URL=https://leads.example.de

# Betrieb OHNE Docker: Verbindung zur PostgreSQL-Datenbank.
# Variante A (empfohlen, robust bei Sonderzeichen im Passwort):
#   PGHOST=localhost
#   PGPORT=5432
#   PGUSER=leadpilot
#   PGPASSWORD=
#   PGDATABASE=leadpilot
# Variante B (Verbindungs-URL; Sonderzeichen im Passwort müssen URL-codiert sein):
#   DATABASE_URL=postgres://leadpilot:<PASSWORD>@localhost:5432/leadpilot
