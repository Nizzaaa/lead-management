# Anthropic API-Key für die KI-Funktionen (Lead-Scoring, E-Mail-Entwürfe, Empfehlungen).
# Ohne diesen Key läuft die App vollständig, nur die KI-Buttons sind dann inaktiv.
ANTHROPIC_API_KEY=sk-ant-...

# Passwort für die PostgreSQL-Datenbank (wird in docker-compose verwendet).
# Standard ist "leadpilot" – für den Produktivbetrieb bitte ändern.
# Sonderzeichen sind erlaubt (die App nutzt PG*-Variablen, keine URL).
POSTGRES_PASSWORD=leadpilot

# Optionaler Port der Web-App (Standard: 3000)
# PORT=3000

# --- Logging ---------------------------------------------------------------
# Log-Level: debug | info | warn | error (Standard: info)
# LOG_LEVEL=info
# Menschenlesbare Ausgabe statt JSON-Lines (für die lokale Entwicklung):
# LOG_PRETTY=1

# --- Einbettung in Nextcloud (iframe) --------------------------------------
# Erlaubt das Einbetten der App per iframe (Nextcloud-App "External Sites").
# Auf die Origin der Nextcloud-Instanz setzen, z. B.:
# FRAME_ANCESTORS=https://cloud.firma.de

# Betrieb OHNE Docker: Verbindung zur PostgreSQL-Datenbank.
# Variante A (empfohlen, robust bei Sonderzeichen im Passwort):
#   PGHOST=localhost
#   PGPORT=5432
#   PGUSER=leadpilot
#   PGPASSWORD=leadpilot
#   PGDATABASE=leadpilot
# Variante B (Verbindungs-URL; Sonderzeichen im Passwort müssen URL-codiert sein):
#   DATABASE_URL=postgres://leadpilot:leadpilot@localhost:5432/leadpilot
