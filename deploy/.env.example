# ===========================================================================
# Gemeinsame Variablen (beide Deployment-Varianten)
# ===========================================================================
# Host des Lead-Systems:
LEAD_DOMAIN=leads.lennartg.de
# Host der Nextcloud-Instanz (darf die App per iframe einbetten):
NC_DOMAIN=cloud.lennartg.de

# App / Datenbank
ANTHROPIC_API_KEY=sk-ant-...
POSTGRES_PASSWORD=ein-sicheres-passwort
# Produktiv eine feste Version pinnen statt :latest:
# LEADPILOT_TAG=1.4.0

# ===========================================================================
# Variante A: Cloudflare Access  (docker-compose.cloudflare.yml) – EMPFOHLEN
# ===========================================================================
# Keine weiteren Variablen nötig. Authentifizierung, TLS und Identitäts-Header
# (Cf-Access-Authenticated-User-Email) konfigurierst du im Cloudflare-Zero-
# Trust-Dashboard – siehe docs/nextcloud-deployment.md.

# ===========================================================================
# Variante B: eigener oauth2-proxy  (docker-compose.nextcloud.yml)
# ===========================================================================
# Gemeinsame Registrar-Domain für das SSO-Cookie (eTLD+1):
COOKIE_DOMAIN=lennartg.de
# Zitadel (OIDC) – Issuer = URL der Zitadel-Instanz:
ZITADEL_ISSUER=https://id.myfu.ge
OIDC_CLIENT_ID=...
OIDC_CLIENT_SECRET=...
# Cookie-Secret für oauth2-proxy (16, 24 ODER 32 Byte). Erzeugen mit:
#   python3 -c 'import os,base64;print(base64.urlsafe_b64encode(os.urandom(32)).decode())'
COOKIE_SECRET=...
# Name des Traefik-Zertifikats-Resolvers (nur Variante B, eigenes TLS):
TRAEFIK_CERTRESOLVER=le
